<div {{ attributes }} class="overlay" data-overlay="just_chatting">
    <h1 class="overlay-title">twitch.tv/toham</h1>
    <section class="overlay-chat chat">
        <div class="chat-title">
            <h1>Chat</h1>
            <hr/>
        </div>
        <div class="chat-messages" {{ react_component('Chat') }}></div>
    </section>
    <div class="overlay-camera"></div>
    <div class="overlay-social-networks">
        <h1>Toham</h1>
        <article class="social-network">
            <span class="icon">
                <svg width="32" viewBox="0 0 300 271" fill="#002156" xmlns="http://www.w3.org/2000/svg">
                    <path d="m236 0h46l-101 115 118 156h-92.6l-72.5-94.8-83 94.8h-46l107-123-113-148h94.9l65.5 86.6zm-16.1 244h25.5l-165-218h-27.4z"></path>
                </svg>
            </span>
            <span class="top">Follow-moi sur X</span>
            <span class="bottom">{{ social_networks.twitter }}</span>
        </article>
        <article class="social-network">
            <span class="icon">

                <svg width="32" viewBox="0 0 159 110" xmlns="http://www.w3.org/2000/svg">
                    <path d="m154 17.5c-1.82-6.73-7.07-12-13.8-13.8-9.04-3.49-96.6-5.2-122 0.1-6.73 1.82-12 7.07-13.8 13.8-4.08 17.9-4.39 56.6 0.1 74.9 1.82 6.73 7.07 12 13.8 13.8 17.9 4.12 103 4.7 122 0 6.73-1.82 12-7.07 13.8-13.8 4.35-19.5 4.66-55.8-0.1-75z"
                          fill="#002156">
                    </path>
                    <path d="m105 55-40.8-23.4v46.8z" fill="#fff"></path>
                </svg>

            </span>
            <span class="top">Tous mes replays sur Youtube</span>
            <span class="bottom">{{ social_networks.youtube }}</span>
        </article>
        <article class="social-network">
            <span class="icon">
                <svg width="32" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
                          fill="#002156">
                    </path>
                </svg>
            </span>
            <span class="top">Tous mes projets sur Github</span>
            <span class="bottom">{{ social_networks.github }}</span>
        </article>
    </div>
    <div class="overlay-community community">
        <article class="community-item">
            <h2>Last subscriber</h2>
            <span>{{ this.lastSubscriber }}</span>
        </article>
        <article class="community-item">
            <h2>Last follower</h2>
            <span>{{ this.lastFollower }}</span>
        </article>
        <article class="community-item">
            <h2>Top cheers</h2>
            <span>{{ this.topCheers }}</span>
        </article>
    </div>
</div>